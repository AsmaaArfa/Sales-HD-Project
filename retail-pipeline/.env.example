# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=GCP_PROJECT_ID
GCP_PROJECT_ID_STAGING=GCP_PROJECT_ID_STAGING
GCP_PROJECT_ID_PROD=GCP_PROJECT_ID_PROD

# ── BigQuery ───────────────────────────────────────────────────────────────────
BQ_DATASET_RAW=retail_raw
BQ_DATASET_STAGING=retail_staging
BQ_DATASET_MART=retail_mart
BQ_LOCATION=US

# ── GCS ───────────────────────────────────────────────────────────────────────
GCS_BUCKET=your-gcs-bucket-name

# ── Dataform ───────────────────────────────────────────────────────────────────
DATAFORM_REPO=Sales-HD-Project
DATAFORM_REGION=us-central1

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////home/airflow/airflow.db
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
ALERT_EMAIL=data-team@company.com

# ── Service Account (local dev only — use GitHub Secrets in CI) ───────────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
